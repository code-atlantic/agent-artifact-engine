{
  "name": "agent-artifact-engine",
  "version": "0.1.0",
  "description": "Self-hostable engine for publishing immutable HTML and safe MDX artifacts.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/http/server.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "start": "node dist/http/server.js",
    "test": "vitest run",
    "static:export": "tsx scripts/export-static.ts",
    "static:serve": "tsx scripts/serve-static.ts"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "hast-util-sanitize": "^5.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
