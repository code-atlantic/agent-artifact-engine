{
  "name": "agent-artifact-engine",
  "version": "0.1.0",
  "description": "Self-hostable engine for publishing immutable HTML and safe MDX artifacts.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core/config": {
      "types": "./dist/core/config.d.ts",
      "import": "./dist/core/config.js"
    },
    "./core/types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js"
    },
    "./core/validation": {
      "types": "./dist/core/validation.d.ts",
      "import": "./dist/core/validation.js"
    },
    "./render/html": {
      "types": "./dist/render/html.d.ts",
      "import": "./dist/render/html.js"
    },
    "./render/mdx": {
      "types": "./dist/render/mdx.d.ts",
      "import": "./dist/render/mdx.js"
    },
    "./render/source": {
      "types": "./dist/render/source.d.ts",
      "import": "./dist/render/source.js"
    },
    "./security/csp": {
      "types": "./dist/security/csp.d.ts",
      "import": "./dist/security/csp.js"
    },
    "./storage/file-store": {
      "types": "./dist/storage/file-store.d.ts",
      "import": "./dist/storage/file-store.js"
    },
    "./utils/hash": {
      "types": "./dist/utils/hash.d.ts",
      "import": "./dist/utils/hash.js"
    },
    "./utils/slug": {
      "types": "./dist/utils/slug.d.ts",
      "import": "./dist/utils/slug.js"
    },
    "./utils/taxonomy": {
      "types": "./dist/utils/taxonomy.d.ts",
      "import": "./dist/utils/taxonomy.js"
    },
    "./utils/url": {
      "types": "./dist/utils/url.d.ts",
      "import": "./dist/utils/url.js"
    },
    "./view/pages": {
      "types": "./dist/view/pages.d.ts",
      "import": "./dist/view/pages.js"
    },
    "./cloudflare/worker": {
      "types": "./dist/cloudflare/worker.d.ts",
      "import": "./dist/cloudflare/worker.js"
    }
  },
  "files": [
    ".dev.vars.example",
    ".env.example",
    "cloudflare",
    "dist",
    "Dockerfile",
    "README.md",
    "docs",
    "railway.toml",
    "wrangler.jsonc"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/http/server.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "cf:pages:build": "npm run static:export",
    "cf:pages:deploy": "wrangler pages deploy static-export",
    "cf:pages:dev": "wrangler pages dev static-export",
    "cf:worker:deploy": "npm run cf:worker:migrate:remote && wrangler deploy",
    "cf:worker:dev": "wrangler dev",
    "cf:worker:migrate": "wrangler d1 migrations apply DB --local",
    "cf:worker:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cf:worker:typecheck": "tsc -p tsconfig.cloudflare.json",
    "check": "npm run build && npm test",
    "deploy": "npm run cf:worker:deploy",
    "start": "node dist/http/server.js",
    "test": "vitest run",
    "static:export": "tsx scripts/export-static.ts",
    "static:serve": "tsx scripts/serve-static.ts"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "hast-util-sanitize": "^5.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "wrangler": "^4.92.0"
  }
}
