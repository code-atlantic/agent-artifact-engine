HOST=0.0.0.0
PORT=3000
DATA_DIR=.data
PUBLIC_BASE_URL=http://127.0.0.1:3000
ARTIFACT_BASE_URL=http://127.0.0.1:3000
MAX_SOURCE_BYTES=1048576
PUBLISH_TOKEN=replace-me-with-a-long-random-token
ARTIFACT_ALLOW_SCRIPTS=false

# Railway templates:
# - attach a volume at /data
# - set DATA_DIR=/data, or let the app use RAILWAY_VOLUME_MOUNT_PATH automatically
# - set PUBLIC_BASE_URL/ARTIFACT_BASE_URL, or let the app use RAILWAY_PUBLIC_DOMAIN automatically
